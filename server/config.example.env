# Private Messenger server configuration
PRIVATE_MESSENGER_ADDR=:8080
PRIVATE_MESSENGER_DATA_DIR=./data
PRIVATE_MESSENGER_DB_PATH=./data/private-messenger.db
PRIVATE_MESSENGER_STORAGE_PATH=./data/blobs
PRIVATE_MESSENGER_INSTANCE_NAME=Private Messenger
# Generate a high-entropy value before remote first-owner setup; remove it afterward.
PRIVATE_MESSENGER_SETUP_TOKEN=
PRIVATE_MESSENGER_ENABLE_METRICS=0
PRIVATE_MESSENGER_MANAGEMENT_ADDR=127.0.0.1:9090
# Optional encrypted Web Push. Configure all three or none.
# PRIVATE_MESSENGER_VAPID_SUBSCRIBER=mailto:security@example.com
# PRIVATE_MESSENGER_VAPID_PUBLIC_KEY=
# PRIVATE_MESSENGER_VAPID_PRIVATE_KEY=
# Comma-separated CIDRs for trusted reverse proxies.
# Example for the bundled Docker Compose network: PRIVATE_MESSENGER_TRUSTED_PROXIES=172.28.250.0/24
PRIVATE_MESSENGER_TRUSTED_PROXIES=
